# Expo only inlines EXPO_PUBLIC_* vars into the client bundle at build time,
# and (like Next.js) does not read the repo root .env -- copy these into
# apps/mobile/.env.local with real values from `npx supabase status -o env`.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps SDK for Android key (apps/mobile/app.config.js), restricted to
# package com.hush.app + your debug keystore's SHA-1 fingerprint in the
# Google Cloud Console. Map display via the native Android SDK is unmetered/
# free; this key is not a secret in the traditional sense (it ships inside
# the built APK either way) but is still kept out of git like every other
# env value here.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
